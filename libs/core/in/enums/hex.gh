pub enum Hex => b8 {
	[0] => 0000_0000,
	[1] => 0000_0001,
	[2] => 0000_0010,
	[3] => 0000_0011,
	[4] => 0000_0100,
	[5] => 0000_0101,
	[6] => 0000_0110,
	[7] => 0000_0111,
	[8] => 0000_1000,
	[9] => 0000_1001,
	[a] => 0000_1010, -- 10
	[b] => 0000_1011, -- 11
	[c] => 0000_1100, -- 12
	[d] => 0000_1101, -- 13
	[e] => 0000_1110, -- 14
	[f] => 0000_1111, -- 15
}
